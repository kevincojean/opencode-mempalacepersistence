{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    ["__PLUGIN_PATH__", {}]
  ],
  "small_model": "test/quick",
  "agent": {
    "build": { "model": "test/quick" }
  },
  "provider": {
    "test": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Test Provider",
      "options": {
        "baseURL": "http://127.0.0.1:__PROVIDER_PORT__/v1",
        "apiKey": "test-key",
        "timeout": 5000
      },
      "models": {
        "quick": { "id": "test-model", "limit": { "context": 1000, "output": 100 } }
      }
    }
  },
  "permission": {
    "*": "deny"
  },
  "share": "disabled",
  "autoupdate": false,
  "formatter": false,
  "username": " ",
  "compaction": {
    "auto": false
  }
}
